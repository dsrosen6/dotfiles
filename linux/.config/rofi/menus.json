{
    "power": [
        {
            "label": "Lock",
            "action": "loginctl lock-session"
        },
        {
            "label": "Sleep",
            "action": "hyprdocked idle"
        },
        {
            "label": "Log Out",
            "action": "hyprshutdown"
        },
        {
            "label": "Reboot",
            "action": "hyprshutdown --post-cmd 'reboot'"
        },
        {
            "label": "Shut Down",
            "action": "shutdown now"
        }
    ],
    "notifications": [
        {
            "label": "Clear All Notifications",
            "action": "swaync-client -C"
        },
        {
            "label": "DND On",
            "conditions": [
                {
                    "command": "swaync-client -D",
                    "value": "false"
                }
            ],
            "action": "swaync-client -dn"
        },
        {
            "label": "DND Off",
            "conditions": [
                {
                    "command": "swaync-client -D",
                    "value": "true"
                }
            ],
            "action": "swaync-client -df"
        }
    ]
}
